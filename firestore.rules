rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile settings
    match /users/{userId} {
      allow read: if true; // Publicly readable for leaderboards
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard entries (copies of user stats for ranking)
    match /leaderboards/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // XP transaction logs for auditing
    match /xpHistory/{logId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid 
                    && (request.resource.data.xpAwarded <= 500); // Prevents excessive mock XP injection
      allow update, delete: if false; // Audit logs are immutable
    }

    // Achievements and Challenges status
    match /achievements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /dailyChallenges/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /weeklyChallenges/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

